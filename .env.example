# Notion API 키
# 발급: https://www.notion.so/my-integrations → 새 연동 생성 → 내부 연동 → API 키 복사
# 형식: ntn_으로 시작하는 문자열
NOTION_API_KEY=ntn_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# 견적서 메인 데이터베이스 ID
# 확인: Notion DB 페이지 URL → https://notion.so/xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx?v=...
# 형식: 32자리 hex (하이픈 없음)
NOTION_INVOICES_DB_ID=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# 견적 항목 데이터베이스 ID
# 확인: 위와 동일한 방법으로 항목 DB URL에서 추출
# 형식: 32자리 hex (하이픈 없음)
NOTION_ITEMS_DB_ID=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
